---
interface Props {
  title: string;
  category: string;
  date: Date;
  coverImage: string;
  location?: string;
  body: string;
}

const { title, category, date, coverImage, location, body } = Astro.props;

const categoryColors: Record<string, string> = {
  travel: 'bg-blue-500/10 text-blue-400 border-blue-500/30',
  food: 'bg-amber-500/10 text-amber-400 border-amber-500/30',
  pets: 'bg-pink-500/10 text-pink-400 border-pink-500/30',
};
---

<article class="group rounded-lg border border-border bg-surface overflow-hidden transition-all duration-300 hover:border-border-hover hover:shadow-[0_4px_24px_rgba(0,0,0,0.4)]" data-category={category}>
  <div class="aspect-video bg-elevated flex items-center justify-center text-text-tertiary">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
      <circle cx="8.5" cy="8.5" r="1.5" />
      <polyline points="21 15 16 10 5 21" />
    </svg>
  </div>

  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class:list={['inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium', categoryColors[category] || 'bg-elevated text-text-secondary border-border']}>
        {category}
      </span>
      {location && (
        <span class="text-xs text-text-tertiary">{location}</span>
      )}
      <span class="text-xs text-text-tertiary ml-auto">
        {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>

    <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent transition-colors mb-2">
      {title}
    </h3>

    <p class="text-sm text-text-secondary leading-relaxed">
      {body}
    </p>
  </div>
</article>
