---
interface Props {
  title: string;
  class?: string;
  accent?: boolean;
}

const { title, class: className, accent = false } = Astro.props;
---

<div
  class:list={[
    'rounded-lg border bg-surface p-6 transition-all duration-300 hover:shadow-[0_4px_24px_rgba(0,0,0,0.4)]',
    accent ? 'border-accent/30 hover:shadow-[0_0_20px_rgba(0,212,170,0.1)]' : 'border-border hover:border-border-hover',
    className,
  ]}
>
  <h3 class="text-sm font-medium text-text-secondary uppercase tracking-wider mb-3">
    {title}
  </h3>
  <slot />
</div>
