---
import { skills } from '../../data/skills';
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {skills.map((group) => (
    <div class="rounded-lg border border-border bg-surface p-6">
      <h3 class="text-sm font-medium text-text-secondary uppercase tracking-wider mb-4">
        {group.category}
      </h3>
      <div class="flex flex-wrap gap-2">
        {group.items.map((skill) => (
          <span class="rounded-full bg-elevated px-3 py-1.5 text-sm font-medium text-text-primary border border-border hover:border-accent/30 hover:text-accent transition-colors">
            {skill}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>
