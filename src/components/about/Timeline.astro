---
import { experience } from '../../data/experience';
---

<div class="relative">
  <!-- Vertical line -->
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-border"></div>

  <div class="space-y-12">
    {experience.map((exp, i) => (
      <div class:list={['relative flex flex-col md:flex-row gap-4 md:gap-8', i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse']}>
        <!-- Dot -->
        <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-accent -translate-x-1/2 mt-1.5 z-10"></div>

        <!-- Content -->
        <div class:list={['ml-10 md:ml-0 md:w-1/2', i % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12']}>
          <span class="text-xs text-accent font-medium">{exp.period}</span>
          <h3 class="text-lg font-semibold text-text-primary mt-1">{exp.title}</h3>
          <p class="text-sm text-text-secondary">{exp.company}</p>
          <p class="text-sm text-text-secondary mt-2 leading-relaxed">{exp.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
