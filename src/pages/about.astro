---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/about/Timeline.astro';
import SkillsMatrix from '../components/about/SkillsMatrix.astro';
import SocialLinks from '../components/shared/SocialLinks.astro';
---

<BaseLayout title="About - Furong Tian" description="Background, experience, and skills">
  <section class="mx-auto max-w-4xl px-6 py-16 md:py-24">
    <!-- Bio -->
    <h1 class="text-3xl md:text-4xl font-bold mb-6">About Me</h1>
    <div class="prose prose-invert max-w-none mb-16">
      <p class="text-text-secondary leading-relaxed text-lg">
        I'm a software engineer with a passion for building robust backend systems and infrastructure.
        I enjoy working on distributed systems, developer tooling, and exploring new ways to write
        software through vibe coding. When I'm not at the keyboard, I'm traveling, exploring food
        scenes around the world, or spending time with my pets.
      </p>
    </div>

    <!-- Experience -->
    <h2 class="text-2xl font-semibold mb-8">Experience</h2>
    <div class="mb-16">
      <Timeline />
    </div>

    <!-- Skills -->
    <h2 class="text-2xl font-semibold mb-8">Skills</h2>
    <div class="mb-16">
      <SkillsMatrix />
    </div>

    <!-- Contact -->
    <div class="rounded-lg border border-border bg-surface p-8 text-center">
      <h2 class="text-xl font-semibold mb-3">Get in Touch</h2>
      <p class="text-text-secondary mb-6">
        Always happy to connect with fellow engineers and creators.
      </p>
      <SocialLinks class="justify-center" />
    </div>
  </section>
</BaseLayout>
